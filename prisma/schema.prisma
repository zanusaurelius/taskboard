generator client {
  provider      = "prisma-client-js"
  engineType    = "client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id @default(cuid())
  username          String       @unique
  passwordHash      String
  recoveryCodeHash  String
  passwordChangedAt DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  notes             Note[]
  folders           Folder[]
  projects          Project[]
  uploads           Upload[]
  fileFolders       FileFolder[]
  attachments       Attachment[]
  dailyGoals        DailyGoal[]
  dailyReflections  DailyReflection[]
  habits            Habit[]
  noteVault         NoteVault?
}

model Project {
  id        String   @id @default(cuid())
  name      String
  encName   String?
  color     String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tasks     Task[]
  notes     Note[]
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  encName   String?
  pinned    Boolean  @default(false)
  hidden    Boolean  @default(false)
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  notes     Note[]
}

model Note {
  id          String       @id @default(cuid())
  title       String       @default("")
  content     String       @default("")
  pinned      Boolean      @default(false)
  starred     Boolean      @default(false)
  hidden      Boolean      @default(false)
  locked      Boolean      @default(false)
  hint        String?
  encContent  String?
  encTitle    String?
  folderId    String?
  folder      Folder?      @relation(fields: [folderId], references: [id])
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id])
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
}

model NoteVault {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  encryptedMasterKey    String   // JSON {iv,ct} — master key encrypted with password-derived key
  masterKeySalt         String   // base64 PBKDF2 salt
  encryptedMasterKeyBak String   // JSON {iv,ct} — master key encrypted with recovery-code-derived key
  backupKeySalt         String   // base64 PBKDF2 salt
  verifier              String   // base64 SHA-256(masterKey) for server-side unlock verification
  webAuthnCredentials   String   @default("[]") // JSON: [{id,publicKey,counter,transports,name}]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Task {
  id             String       @id @default(cuid())
  title          String
  encTitle       String?
  description    String?
  encDescription String?
  stage          String       @default("todo")
  priority       String?
  dueDate        String?
  position       Float        @default(0)
  archived       Boolean      @default(false)
  sensitive      Boolean      @default(false)
  locked         Boolean      @default(false)
  doneAt         DateTime?
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  attachments    Attachment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model FileFolder {
  id        String       @id @default(cuid())
  name      String
  parentId  String?
  parent    FileFolder?  @relation("FileFolderTree", fields: [parentId], references: [id])
  children  FileFolder[] @relation("FileFolderTree")
  uploads   Upload[]
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
  @@index([parentId])
}

model Upload {
  id           String      @id @default(cuid())
  filename     String      @unique
  originalName String      @default("")
  mimeType     String
  size         Int         @default(0)
  thumbnail    String?
  fileFolderId String?
  fileFolder   FileFolder? @relation(fields: [fileFolderId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([fileFolderId])
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String   @unique
  originalName String
  mimeType     String
  size         Int
  noteId       String?
  note         Note?    @relation(fields: [noteId], references: [id])
  taskId       String?
  task         Task?    @relation(fields: [taskId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@index([noteId])
  @@index([taskId])
  @@index([userId])
}

model RateLimit {
  id  String   @id @default(cuid())
  key String
  hit DateTime @default(now())

  @@index([key, hit])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  ip        String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model DailyGoal {
  id        String   @id @default(cuid())
  text      String
  encText   String?
  taskId    String?
  date      String
  completed Boolean  @default(false)
  position  Int      @default(0)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

model Habit {
  id          String            @id @default(cuid())
  text        String
  encText     String?
  position    Int               @default(0)
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  completions HabitCompletion[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model HabitCompletion {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      String
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
}

model DailyReflection {
  id          String  @id @default(cuid())
  date        String
  note        String?
  encNote     String?
  gratitude   String?
  encGratitude String?
  body        String?
  encBody     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}
