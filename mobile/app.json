{
  "expo": {
    "name": "Taskboard",
    "slug": "taskboard",
    "scheme": "taskboard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "react-native-quick-crypto",
      ["expo-build-properties", {
        "android": {
          "usesCleartextTraffic": true,
          "ndkVersion": "28.0.12433566"
        }
      }],
      ["expo-image-picker", {
        "photosPermission": "Allow Taskboard to attach photos to notes and tasks.",
        "cameraPermission": "Allow Taskboard to take photos to attach to notes and tasks."
      }]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taskboard.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.taskboard.app",
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {}
    }
  }
}
